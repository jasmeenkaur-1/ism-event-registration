{% extends 'base.html.twig' %}
{% block title %}Admin Panel{% endblock %}
{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color:#1c2b4a">Admin Panel — Registrations</h2>
        <div class="d-flex flex-wrap gap-2">
            <a href="/admin/export" class="btn btn-ism">Download Excel</a>
            <a href="/admin/attendance-pdf" class="btn btn-ism">Attendance List PDF</a>
            <a href="/admin/nametags-pdf" class="btn btn-ism">Name Tags PDF</a>
            <a href="/" class="btn btn-ism-outline">Back to Site</a>
        </div>
    </div>

    {% if summit %}
    <div class="alert" style="background:#f5f5f5; border-left:4px solid #f0a500;">
        <strong>Active Summit:</strong> {{ summit.title }} —
        {{ summit.location.city }} —
        {{ summit.location.evenDate|date('d.m.Y') }} —
        <strong>{{ registrations|length }}/{{ summit.location.capacity }}</strong> registered
    </div>
    {% endif %}

    <table class="table table-hover" id="regTable">
        <thead style="background:#1c2b4a; color:white;">
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Company</th>
                <th>Meal</th>
                <th>Ticket No</th>
                <th>Registered</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for r in registrations %}
            <tr>
                <td>{{ r.id }}</td>
                <td>{{ r.firstName }} {{ r.lastName }}</td>
                <td>{{ r.email }}</td>
                <td>{{ r.company ?? '—' }}</td>
                <td>{{ r.mealPreference }}</td>
                <td><span style="color:#1c2b4a; font-weight:600;">{{ r.ticketNumber }}</span></td>
                <td>{{ r.registeredAt|date('d.m.Y H:i') }}</td>
                <td>
                    <a href="/admin/edit/{{ r.id }}" class="btn btn-sm btn-warning me-1">Edit</a>
                    <a href="/admin/delete/{{ r.id }}"
                       onclick="return confirm('Delete this registration?')"
                       class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if registrations|length == 0 %}
    <p class="text-muted text-center mt-4">No registrations yet.</p>
    {% endif %}
</div>

{% block javascripts %}
<script>
$(document).ready(function() {
    $('#regTable thead th').not(':last').css('cursor','pointer').click(function() {
        var table = $(this).parents('table');
        var rows = table.find('tbody tr').toArray().sort(comparer($(this).index()));
        this.asc = !this.asc;
        if (!this.asc) rows = rows.reverse();
        $.each(rows, function(index, row) { table.children('tbody').append(row); });
    });
    function comparer(index) {
        return function(a, b) {
            var A = getCellValue(a, index), B = getCellValue(b, index);
            return $.isNumeric(A) && $.isNumeric(B) ? A - B : A.toString().localeCompare(B);
        };
    }
    function getCellValue(row, index) { return $(row).children('td').eq(index).text(); }
});
</script>
{% endblock %}
{% endblock %}